---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getPublishedPosts, getPostsByTag, slugifyTag } from '../../utils/posts';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  const tagSet = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      tagSet.add(tag.toLowerCase());
    }
  }
  return [...tagSet].map((tag) => ({
    params: { tag: slugifyTag(tag) },
    props: {
      tag,
      posts: getPostsByTag(posts, tag),
    },
  }));
}) satisfies GetStaticPaths;

const { tag, posts } = Astro.props;
const displayTag = tag.charAt(0).toUpperCase() + tag.slice(1);
---

<BaseLayout title={`#${displayTag}`} description={`Articles tagged with ${displayTag}.`}>
  <div class="container-wide py-12 lg:py-16">
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Tags', href: '/tags/' },
        { label: `#${displayTag}` },
      ]}
    />
    <h1 class="mt-6 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
      #{displayTag}
    </h1>
    <p class="mt-4 text-foreground-secondary">
      {posts.length} {posts.length === 1 ? 'article' : 'articles'}
    </p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <ArticleCard post={post} />
      ))}
    </div>
  </div>
</BaseLayout>
