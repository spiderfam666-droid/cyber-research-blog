---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getPublishedPosts, getAllTags } from '../../utils/posts';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
---

<BaseLayout title="Tags" description="Browse articles by tag.">
  <div class="container-wide py-12 lg:py-16">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Tags' }]} />
    <h1 class="mt-6 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">Tags</h1>
    <p class="mt-4 text-foreground-secondary">
      {tags.length} tags across {posts.length} articles
    </p>

    <div class="mt-10 flex flex-wrap gap-3">
      {tags.map(({ tag, count }) => (
        <a
          href={`${import.meta.env.BASE_URL}tags/${tag.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}/`}
          class="inline-flex items-center gap-2 rounded-full border border-border bg-surface-elevated px-4 py-2 text-sm text-foreground-secondary transition-colors hover:border-accent/50 hover:text-accent"
        >
          <span>#{tag}</span>
          <span class="text-xs text-muted">{count}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
