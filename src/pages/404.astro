---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" noindex={true}>
  <div class="container-wide flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
    <p class="text-6xl font-bold text-accent">404</p>
    <h1 class="mt-4 text-2xl font-semibold text-foreground">Page not found</h1>
    <p class="mt-2 max-w-md text-foreground-secondary">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href={`${import.meta.env.BASE_URL}`}
      class="mt-8 rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white hover:bg-accent-hover"
    >
      Back to Home
    </a>
  </div>
</BaseLayout>
