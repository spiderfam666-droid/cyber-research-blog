---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Pagination from '../../components/Pagination.astro';
import Sidebar from '../../components/Sidebar.astro';
import TagChip from '../../components/TagChip.astro';
import { getPublishedPosts, getAllTags } from '../../utils/posts';

const POSTS_PER_PAGE = 6;
const posts = await getPublishedPosts();
const tags = getAllTags(posts).slice(0, 10);
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
const pagePosts = posts.slice(0, POSTS_PER_PAGE);
---

<BaseLayout title="Blog" description="Security research blog with technical write-ups and analysis.">
  <div class="container-wide py-12 lg:py-16">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Blog' }]} />
    <div class="mt-6 grid gap-12 lg:grid-cols-[1fr_280px]">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">Blog</h1>
        <p class="mt-4 text-foreground-secondary">
          Technical write-ups, attack chain analysis, and defensive guidance.
        </p>

        <div class="mt-10 grid gap-6 sm:grid-cols-2">
          {pagePosts.map((post) => (
            <ArticleCard post={post} />
          ))}
        </div>

        <Pagination currentPage={1} totalPages={totalPages} basePath="/blog" />
      </div>

      <aside class="space-y-6">
        <Sidebar title="Popular Tags">
          <div class="flex flex-wrap gap-2">
            {tags.map(({ tag }) => (
              <TagChip tag={tag} />
            ))}
          </div>
        </Sidebar>
      </aside>
    </div>
  </div>
</BaseLayout>
