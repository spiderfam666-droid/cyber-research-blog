---
interface Props {
  tag: string;
  size?: 'sm' | 'md';
}

const { tag, size = 'sm' } = Astro.props;
const slug = tag.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
---

<a
  href={`${import.meta.env.BASE_URL}tags/${slug}/`}
  class:list={[
    'inline-flex items-center rounded-full border border-border bg-surface-elevated font-medium text-foreground-secondary transition-colors hover:border-accent/50 hover:text-accent',
    size === 'sm' ? 'px-2.5 py-0.5 text-xs' : 'px-3 py-1 text-sm',
  ]}
>
  #{tag}
</a>
