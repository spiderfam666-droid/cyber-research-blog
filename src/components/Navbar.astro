---
import { SITE, NAV_LINKS } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="sticky top-0 z-50 border-b border-border/80 bg-surface/80 backdrop-blur-md">
  <nav class="container-wide flex h-16 items-center justify-between" aria-label="Main navigation">
    <a
      href={`${import.meta.env.BASE_URL}`}
      class="flex items-center gap-2 text-sm font-semibold tracking-tight text-foreground hover:text-accent"
    >
      <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
      </svg>
      <span class="hidden sm:inline">{SITE.author}</span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {NAV_LINKS.map((link) => {
        const href = `${import.meta.env.BASE_URL}${link.href === '/' ? '' : link.href.slice(1)}`;
        const isActive = Astro.url.pathname === link.href || 
          (link.href !== '/' && Astro.url.pathname.startsWith(link.href));
        return (
          <a
            href={href}
            class:list={[
              'rounded-md px-3 py-2 text-sm transition-colors',
              isActive
                ? 'bg-surface-elevated text-foreground'
                : 'text-foreground-secondary hover:text-foreground',
            ]}
            aria-current={isActive ? 'page' : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </div>

    <div class="flex items-center gap-2">
      <a
        href={`${import.meta.env.BASE_URL}search/`}
        class="rounded-md p-2 text-foreground-secondary hover:bg-surface-elevated hover:text-foreground"
        aria-label="Search"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </a>
      <ThemeToggle />

      <button
        id="mobile-menu-btn"
        class="rounded-md p-2 text-foreground-secondary hover:bg-surface-elevated md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="hidden border-t border-border bg-surface md:hidden"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <div class="container-wide space-y-1 py-4">
      {NAV_LINKS.map((link) => {
        const href = `${import.meta.env.BASE_URL}${link.href === '/' ? '' : link.href.slice(1)}`;
        return (
          <a
            href={href}
            class="block rounded-md px-3 py-2 text-sm text-foreground-secondary hover:bg-surface-elevated hover:text-foreground"
          >
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
